#!/bin/bash

# ============================================
# Certificate Generator Backend - QA Test Suite
# ============================================
# Comprehensive test coverage for all APIs
# Tests: Functionality, Validation, Error Handling, Data Persistence

set -e

BASE_URL="${BASE_URL:-http://localhost:4000}"
VERBOSE="${VERBOSE:-false}"
CLEANUP="${CLEANUP:-true}"

# Colors
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Counters
TOTAL=0
PASSED=0
FAILED=0

# Test data storage (simple variables)
TEMPLATE1_ID=""
ASSET1_ID=""
ASSET2_ID=""
FONT1_ID=""
FONT2_ID=""

# ============================================
# Utility Functions
# ============================================

log_info() {
  echo -e "${BLUE}ℹ${NC} $*"
}

log_test() {
  echo -e "${YELLOW}Test:${NC} $*"
  ((TOTAL++))
}

log_pass() {
  echo -e "${GREEN}✓ PASS${NC} $*"
  ((PASSED++))
}

log_fail() {
  echo -e "${RED}✗ FAIL${NC} $*"
  ((FAILED++))
}

# API call helper
api_call() {
  local method=$1
  local endpoint=$2
  local data=$3
  local expected_code=$4
  
  local response
  if [ -z "$data" ]; then
    response=$(curl -s -w "\n%{http_code}" -X "$method" "$BASE_URL$endpoint" \
      -H "Content-Type: application/json" 2>/dev/null)
  else
    response=$(curl -s -w "\n%{http_code}" -X "$method" "$BASE_URL$endpoint" \
      -H "Content-Type: application/json" \
      -d "$data" 2>/dev/null)
  fi
  
  local http_code=$(echo "$response" | tail -n 1)
  local body=$(echo "$response" | sed '$d')
  
  if [ "$http_code" = "$expected_code" ]; then
    [ "$VERBOSE" = "true" ] && echo "$body"
    echo "$body"
    return 0
  else
    log_fail "HTTP $http_code (expected $expected_code)"
    echo "$body"
    return 1
  fi
}

# Extract ID from JSON response
extract_id() {
  echo "$1" | grep -o '"id":[0-9]*' | head -1 | grep -o '[0-9]*'
}

# ============================================
# Test Suites
# ============================================

test_health_check() {
  log_info "Testing Health Check"
  
  log_test "Health endpoint responds"
  if api_call "GET" "/health" "" "200" > /dev/null; then
    log_pass "Health check"
  else
    log_fail "Health check"
    return 1
  fi
}

test_templates_crud() {
  log_info "Testing Templates API - CRUD Operations"
  
  # CREATE
  log_test "Create template"
  local template='{"name":"QA Test Template","layout":{"width":800,"height":600,"fields":[]}}'
  local response=$(api_call "POST" "/api/templates" "$template" "201")
  if [ $? -eq 0 ]; then
    log_pass "Create template"
    TEST_IDS[template1]=$(extract_id "$response")
  else
    log_fail "Create template"
    return 1
  fi
  
  # READ ALL
  log_test "Get all templates"
  if api_call "GET" "/api/templates" "" "200" > /dev/null; then
    log_pass "Get all templates"
  else
    log_fail "Get all templates"
  fi
  
  # READ ONE
  log_test "Get single template"
  if api_call "GET" "/api/templates/${TEST_IDS[template1]}" "" "200" > /dev/null; then
    log_pass "Get single template"
  else
    log_fail "Get single template"
  fi
  
  # UPDATE
  log_test "Update template"
  local update='{"name":"Updated Template","layout":{"width":1000,"height":700}}'
  if api_call "PUT" "/api/templates/${TEST_IDS[template1]}" "$update" "200" > /dev/null; then
    log_pass "Update template"
  else
    log_fail "Update template"
  fi
  
  # DELETE
  log_test "Delete template"
  if api_call "DELETE" "/api/templates/${TEST_IDS[template1]}" "" "200" > /dev/null; then
    log_pass "Delete template"
  else
    log_fail "Delete template"
  fi
}

test_templates_validation() {
  log_info "Testing Templates API - Validation"
  
  log_test "Reject missing name field"
  local bad_data='{"layout":{}}'
  if api_call "POST" "/api/templates" "$bad_data" "400" > /dev/null 2>&1; then
    log_pass "Validation: missing name"
  else
    log_fail "Validation: missing name"
  fi
  
  log_test "Reject missing layout field"
  local bad_data='{"name":"Test"}'
  if api_call "POST" "/api/templates" "$bad_data" "400" > /dev/null 2>&1; then
    log_pass "Validation: missing layout"
  else
    log_fail "Validation: missing layout"
  fi
  
  log_test "Return 404 for non-existent template"
  if api_call "GET" "/api/templates/99999" "" "404" > /dev/null 2>&1; then
    log_pass "Not found handling"
  else
    log_fail "Not found handling"
  fi
}

test_assets_upload() {
  log_info "Testing Assets API - Upload & Management"
  
  # Create test images
  xxd -r -p > /tmp/qa-test-image.png << 'EOF'
89504e470d0a1a0a0000000d49484452000000010000000108060000001f15c4890000000d49444154785e63f8cf00000301000080000126f52d14
EOF
  
  log_test "Upload PNG asset"
  local response=$(curl -s -X POST "$BASE_URL/api/assets" \
    -F "file=@/tmp/qa-test-image.png" \
    -F "type=logo" 2>/dev/null)
  
  if echo "$response" | grep -q '"id"'; then
    log_pass "Upload PNG asset"
    TEST_IDS[asset1]=$(extract_id "$response")
  else
    log_fail "Upload PNG asset"
  fi
  
  log_test "Verify image metadata extraction"
  local response=$(api_call "GET" "/api/assets" "" "200")
  if echo "$response" | grep -q '"width"'; then
    log_pass "Metadata extraction"
  else
    log_fail "Metadata extraction"
  fi
  
  log_test "Upload with different type (background)"
  local response=$(curl -s -X POST "$BASE_URL/api/assets" \
    -F "file=@/tmp/qa-test-image.png" \
    -F "type=background" 2>/dev/null)
  
  if echo "$response" | grep -q '"type":"background"'; then
    log_pass "Asset type handling"
    TEST_IDS[asset2]=$(extract_id "$response")
  else
    log_fail "Asset type handling"
  fi
}

test_assets_validation() {
  log_info "Testing Assets API - Validation"
  
  log_test "Reject upload without file"
  if api_call "POST" "/api/assets" "" "400" > /dev/null 2>&1; then
    log_pass "Validation: no file"
  else
    log_fail "Validation: no file"
  fi
  
  log_test "Return 404 for non-existent asset"
  if api_call "DELETE" "/api/assets/99999" "" "404" > /dev/null 2>&1; then
    log_pass "Not found handling"
  else
    log_fail "Not found handling"
  fi
}

test_assets_delete() {
  log_info "Testing Assets API - Deletion"
  
  if [ -n "${TEST_IDS[asset1]}" ]; then
    log_test "Delete asset"
    if api_call "DELETE" "/api/assets/${TEST_IDS[asset1]}" "" "200" > /dev/null; then
      log_pass "Delete asset"
    else
      log_fail "Delete asset"
    fi
  fi
}

test_fonts_upload() {
  log_info "Testing Fonts API - Upload & Management"
  
  # Create test fonts
  xxd -r -p > /tmp/qa-test-regular.ttf << 'EOF'
00010000
EOF
  
  xxd -r -p > /tmp/qa-test-bold.ttf << 'EOF'
00010000
EOF
  
  log_test "Upload single font"
  local response=$(curl -s -X POST "$BASE_URL/api/fonts" \
    -F "files=@/tmp/qa-test-regular.ttf" \
    -F "fontFamily=TestFont" 2>/dev/null)
  
  if echo "$response" | grep -q '"uploaded":1'; then
    log_pass "Upload single font"
    TEST_IDS[font1]=$(echo "$response" | grep -o '"id":[0-9]*' | head -1 | grep -o '[0-9]*')
  else
    log_fail "Upload single font"
  fi
  
  log_test "Upload multiple fonts at once"
  local response=$(curl -s -X POST "$BASE_URL/api/fonts" \
    -F "files=@/tmp/qa-test-regular.ttf" \
    -F "files=@/tmp/qa-test-bold.ttf" \
    -F "fontFamily=TestFont2" 2>/dev/null)
  
  if echo "$response" | grep -q '"uploaded":2'; then
    log_pass "Upload multiple fonts"
    TEST_IDS[font2]=$(echo "$response" | grep -o '"id":[0-9]*' | head -1 | grep -o '[0-9]*')
  else
    log_fail "Upload multiple fonts"
  fi
  
  log_test "Verify font weight detection"
  local response=$(api_call "GET" "/api/fonts" "" "200")
  if echo "$response" | grep -q '"fontWeight":"400"'; then
    log_pass "Font weight detection"
  else
    log_fail "Font weight detection"
  fi
}

test_fonts_validation() {
  log_info "Testing Fonts API - Validation"
  
  log_test "Reject upload without fontFamily"
  if api_call "POST" "/api/fonts" "" "400" > /dev/null 2>&1; then
    log_pass "Validation: missing fontFamily"
  else
    log_fail "Validation: missing fontFamily"
  fi
  
  log_test "Return 404 for non-existent font"
  if api_call "DELETE" "/api/fonts/99999" "" "404" > /dev/null 2>&1; then
    log_pass "Not found handling"
  else
    log_fail "Not found handling"
  fi
}

test_fonts_delete() {
  log_info "Testing Fonts API - Deletion"
  
  if [ -n "${TEST_IDS[font1]}" ]; then
    log_test "Delete font"
    if api_call "DELETE" "/api/fonts/${TEST_IDS[font1]}" "" "200" > /dev/null; then
      log_pass "Delete font"
    else
      log_fail "Delete font"
    fi
  fi
}

test_cors() {
  log_info "Testing CORS Configuration"
  
  log_test "CORS headers present"
  local response=$(curl -s -i "$BASE_URL/health" 2>/dev/null | grep -i "access-control-allow-origin")
  if [ -n "$response" ]; then
    log_pass "CORS headers"
  else
    log_fail "CORS headers"
  fi
}

# ============================================
# Cleanup
# ============================================

cleanup() {
  if [ "$CLEANUP" = "true" ]; then
    log_info "Cleaning up test files"
    rm -f /tmp/qa-test-*.png /tmp/qa-test-*.ttf 2>/dev/null || true
  fi
}

# ============================================
# Main Execution
# ============================================

main() {
  echo "======================================"
  echo "Backend QA Test Suite"
  echo "======================================"
  echo "URL: $BASE_URL"
  echo ""
  
  test_health_check
  test_templates_crud
  test_templates_validation
  test_assets_upload
  test_assets_validation
  test_assets_delete
  test_fonts_upload
  test_fonts_validation
  test_fonts_delete
  test_cors
  
  cleanup
  
  echo ""
  echo "======================================"
  echo "Test Summary"
  echo "======================================"
  echo -e "Total: $TOTAL"
  echo -e "Passed: ${GREEN}$PASSED${NC}"
  echo -e "Failed: ${RED}$FAILED${NC}"
  echo "======================================"
  
  if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}All tests passed!${NC}"
    return 0
  else
    echo -e "${RED}Some tests failed!${NC}"
    return 1
  fi
}

main "$@"
