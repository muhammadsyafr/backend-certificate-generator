# ============================================
# Backend — Certificate Generator API
# Copy to .env and fill in your values
# ============================================

# Server
PORT=4000
NODE_ENV=development

# Database (SQLite stored in DATA_DIR)
DATA_DIR=./data

# CORS — comma-separated origins allowed
CORS_ORIGIN=http://localhost:3000

# JWT
# Generate production secret: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production-use-strong-random-string